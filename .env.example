# NexoCrypto — environment variables (copy to .env, never commit real secrets)

# ── App ──
APP_ENV=local                      # local|staging|prod
APP_DEFAULT_LOCALE=es              # Spanish-first; en fallback
LOG_LEVEL=info

# ── Supabase (reuse the nexo-ai.world project) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=         # server-side only, NEVER exposed to the browser
SUPABASE_DB_SCHEMA=nexocrypto
SUPABASE_JWT_SECRET=               # FastAPI verifies user JWTs against this

# ── Secret encryption (envelope encryption for API keys & TG sessions) ──
MASTER_ENCRYPTION_KEY=             # 32-byte base64; source from KMS in prod, never in DB

# ── Redis / Celery ──
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Trading venues (per-user keys live encrypted in DB; these are platform defaults) ──
BITUNIX_ENABLED=true
LBANK_ENABLED=true
# Binance is OPTIONAL and DATA-ONLY (free historical klines for backtests; no keys, no live trading)
BINANCE_BACKTEST_DATA_ENABLED=true
BINANCE_DATA_BASE_URL=             # public market-data base; no account required

# ── Coinglass (derivatives context: OI, funding, liquidation heatmaps, long/short) ──
# commercial use (nexo-ai.world product) needs Standard tier ($299/mo+); lower tiers are personal, <=1min
COINGLASS_API_KEY=
COINGLASS_BASE_URL=                # verify current V4 base in docs.coinglass.com

# ── CoinMarketCap (market context only: ranking/trending/market-cap/pair validation) ──
COINMARKETCAP_API_KEY=
COINMARKETCAP_BASE_URL=https://pro-api.coinmarketcap.com

# ── Telegram ──
# ingest (Telethon / MTProto user session — reads channels the user follows)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# session strings are per-user, stored encrypted in DB — not here
# control bot (Bot API — notifications + inline keyboards)
TELEGRAM_BOT_TOKEN=

# ── LLM layer (async only, never in the execution hot path) ──
ANTHROPIC_API_KEY=                 # Claude = trading analyst (explanations/plans/digests)
ANTHROPIC_MODEL=claude-opus-4-8
QWEN_BASE_URL=http://host.docker.internal:11434   # local Ollama, optional enrichment
QWEN_MODEL=qwen2.5:7b-instruct-q4_K_M

# ── Email fallback (reuse nexo-ai.world Resend) ──
RESEND_API_KEY=
RESEND_FROM=alerts@nexo-ai.world

# ── Risk defaults (overridable per risk_profile in DB) ──
RISK_MAX_RISK_PER_TRADE_PCT=0.5
RISK_MAX_DAILY_LOSS_PCT=3
RISK_MAX_WEEKLY_LOSS_PCT=8
RISK_MAX_DRAWDOWN_PCT=15
RISK_MAX_OPEN_POSITIONS=3
RISK_MAX_LEVERAGE=20               # 50x is advanced opt-in, not default
RISK_MIN_RR=1.5
RISK_MIN_ADX=20
RISK_MIN_LIQUIDATION_DISTANCE_PCT=2
RISK_PROTECTED_PROFIT_GIVEBACK=0.30  # ratcheting net floor (ARCHITECTURE §6)
RISK_COOLDOWN_AFTER_LOSS_MIN=15
RISK_STALE_PRICE_MAX_SECONDS=5
RISK_MIN_PAPER_TRADES_BEFORE_LIVE=50

# ── Fees (seed for fee_schedules table; editable in-app, bps where 5.0 = 0.05%) ──
FEE_BINANCE_MAKER_BPS=2.0
FEE_BINANCE_TAKER_BPS=5.0
FEE_LBANK_MAKER_BPS=2.0
FEE_LBANK_TAKER_BPS=6.0
FEE_BITUNIX_MAKER_BPS=2.0
FEE_BITUNIX_TAKER_BPS=6.0
